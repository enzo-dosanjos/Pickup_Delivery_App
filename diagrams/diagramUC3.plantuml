@startuml
title UC – Importer Pickup-Delivery depuis un fichier

actor User
participant "RequestController" as RC
participant "RequestService" as RS
participant "XMLParsers" as XP
participant "PickupDelivery" as PD

alt Normal flow
    User -> RC : loadRequests(filepath, courierId)
    activate RC

    RC -> RS : loadRequests(filepath, courierId)
    activate RS

        RS -> XP : parseRequests(filepath, courierId, pickupDeliveryToFill)
        activate XP
        XP --> RS : PickupDelivery (requests loaded)
        deactivate XP

        RS -> PD : update with new requests
        activate PD
        PD --> RS : updated data
        deactivate PD

    RS --> RC : PickupDelivery loaded successfully
    deactivate RS

    RC --> User : "Demandes de livraison importées avec succès"
    deactivate RC

else Error during XML parsing or file loading
    RC --> User : "Erreur lors de l'import du fichier de demandes"
end
@enduml