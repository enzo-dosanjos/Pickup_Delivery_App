@startuml
title UC9 – Importer un plan

actor User
participant "MapController" as MC
participant "MapService" as MS
participant "XMLParsers" as XP
participant "Map" as MAP

alt Normal flow
    User -> MC : loadMap(filePath)
    activate MC

    MC -> MS : loadMap(filePath)
    activate MS

        MS -> XP : parseMap(filePath)
        activate XP
        XP --> MAP : Map (parsed city network)
        deactivate XP

      
        activate MAP
        MAP --> MS : confirmation
        deactivate MAP

    MS --> MC : Map loaded
    deactivate MS

    MC --> User : "Plan chargé avec succès"
    deactivate MC

else Error: invalid or missing file
    MC --> User : "Erreur : impossible de charger le plan"
end
@enduml