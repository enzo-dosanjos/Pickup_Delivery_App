@startuml
title UC12 – Consulter les détails d'une étape 

actor User
participant "UI (MapView)" as UI
participant "TourController" as TC
participant "TourService" as TS
participant "Tour" as T
participant "TourStop" as TSStop
participant "Courier" as C
participant "MapService" as MS
participant "Map" as MAP
participant "RoadSegment" as RS

alt Normal flow
    User -> UI : hoverPoint(intersectionId)
    activate UI

    UI -> TC : showRequestDetails(intersectionId)
    activate TC

    TC -> TS : getTourForIntersection(intersectionId)
    activate TS
        TS -> T : getStopByIntersectionId(intersectionId)
        activate T
        T --> TS : TourStop (arrivalTime, departureTime, type, intersectionId)
        deactivate T

        TS -> C : getCourierForTour(Tour)
        activate C
        C --> TS : Courier(name, shiftDuration)
        deactivate C
    TS --> TC : TourStop + Courier
    deactivate TS

    TC -> MS : getMap()
    activate MS
        MS -> MAP : getRoadSegment(prevId, intersectionId)
        activate MAP
        MAP --> MS : RoadSegment(name, length)
        deactivate MAP
    MS --> TC : RoadSegment
    deactivate MS

    TC --> UI : display(details: TourStop + RoadSegment + Courier)
    deactivate TC

    UI --> User : show popup with details
    deactivate UI

else Error: étape introuvable
    TC --> UI : show "Étape non trouvée"
    UI --> User : error message displayed
end
@enduml